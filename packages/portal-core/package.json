{
  "name": "@monigo/portal-core",
  "version": "0.3.2",
  "description": "Framework-agnostic core for Monigo customer-portal UI: typed API client, per-feature state stores, formatters, and message catalog.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "codegen": "swagger2openapi ${OPENAPI_SPEC:-../../../../platform/docs/openapi.yaml} -o /tmp/openapi3-portal-core.yaml && openapi-typescript /tmp/openapi3-portal-core.yaml -o src/generated/api-types.ts",
    "codegen:check": "swagger2openapi ${OPENAPI_SPEC:-../../../../platform/docs/openapi.yaml} -o /tmp/openapi3-check.yaml && openapi-typescript /tmp/openapi3-check.yaml -o /tmp/api-types-check.ts && diff src/generated/api-types.ts /tmp/api-types-check.ts"
  },
  "dependencies": {
    "@monigo/sdk": "^0.1.8"
  },
  "devDependencies": {
    "openapi-typescript": "7",
    "swagger2openapi": "^7.0.8",
    "tsup": "^8.3.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.3"
  }
}
