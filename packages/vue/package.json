{
  "name": "@monigo/vue",
  "version": "0.3.0",
  "description": "Vue 3.4+ customer-portal building blocks and composed portal for Monigo.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "vue-tsc --noEmit"
  },
  "peerDependencies": {
    "vue": ">=3.4.0"
  },
  "dependencies": {
    "@monigo/portal-core": "workspace:*",
    "@monigo/tokens": "workspace:*"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.1.4",
    "@vue/compiler-sfc": "^3.4.0",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^25.0.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vite-plugin-dts": "^4.2.4",
    "vitest": "^2.1.3",
    "vue": "^3.4.0",
    "vue-tsc": "^2.1.6"
  }
}
